{
  "name": "transitrix-studio",
  "displayName": "Transitrix Studio",
  "publisher": "transitrix",
  "version": "0.4.8",
  "description": "Preview Transitrix diagrams (BPMN, Goals, FGCA, …) inside VS Code.",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/transitrix/transitrix-studio#readme",
  "bugs": {
    "url": "https://github.com/transitrix/transitrix-studio/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/transitrix/transitrix-studio.git"
  },
  "keywords": [
    "bpmn",
    "transitrix",
    "diagram",
    "enterprise-architecture"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "type": "module",
  "activationEvents": [
    "workspaceContains:**/*.cervin.yaml",
    "workspaceContains:**/*.bpmn.yaml",
    "workspaceContains:**/*.goals.transitrix.yaml"
  ],
  "contributes": {
    "configuration": {
      "title": "Transitrix Studio",
      "properties": {
        "cervin.fileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".cervin.yaml",
            ".bpmn.yaml"
          ],
          "description": "File suffixes recognized as Transitrix BPMN source files (must include the leading dot)."
        },
        "cervin.exportEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Show experimental BPMN/SVG/PNG export commands (not finished yet)."
        },
        "transitrix.theme": {
          "type": "string",
          "enum": [
            "transitrix",
            "transitrix-dark",
            "vscode-adaptive"
          ],
          "enumDescriptions": [
            "Transitrix light theme (default)",
            "Transitrix dark theme",
            "Follow the active VS Code color theme"
          ],
          "default": "transitrix",
          "description": "Color theme for Transitrix diagram previews (Goals, FGCA, and other static notation previews)."
        },
        "transitrix.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python 3 executable used for nested block diagram previews. Leave empty to auto-detect: 'py' on Windows (Python Launcher), 'python3' on macOS/Linux. Example: /usr/local/bin/python3 or C:\\Python311\\python.exe"
        },
        "transitrix.svgbobPath": {
          "type": "string",
          "default": "",
          "description": "Path to the svgbob_cli executable used for nested block diagram previews. Leave empty to use 'svgbob_cli' from PATH. Install with: cargo install svgbob_cli"
        }
      }
    },
    "languages": [
      {
        "id": "cervin-yaml",
        "aliases": [
          "Transitrix BPMN YAML",
          "BPMN YAML"
        ],
        "extensions": [
          ".cervin.yaml",
          ".bpmn.yaml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "transitrix-goals",
        "aliases": [
          "Transitrix Goals",
          "Goals Tree"
        ],
        "extensions": [
          ".goals.transitrix.yaml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "transitrix-fga",
        "aliases": [
          "Transitrix FGA",
          "Factor-Goal-Activity"
        ],
        "extensions": [
          ".fga.transitrix.yaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "cervin.openPreview",
        "title": "Transitrix: Open Preview",
        "category": "Transitrix",
        "icon": "$(graph)"
      },
      {
        "command": "cervin.exportSvg",
        "title": "Transitrix: Export as SVG",
        "category": "Transitrix",
        "enablement": "config.cervin.exportEnabled"
      },
      {
        "command": "cervin.exportPng",
        "title": "Transitrix: Export as PNG",
        "category": "Transitrix",
        "enablement": "config.cervin.exportEnabled"
      },
      {
        "command": "cervin.exportBpmn",
        "title": "Transitrix: Export as .bpmn",
        "category": "Transitrix",
        "enablement": "config.cervin.exportEnabled"
      },
      {
        "command": "transitrixStudio.previewGoals",
        "title": "Transitrix: Preview goal tree",
        "category": "Transitrix",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "transitrixStudio.previewFGCA",
        "title": "Transitrix: Preview FGCA diagram",
        "category": "Transitrix",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "transitrixStudio.previewFGA",
        "title": "Transitrix: Preview FGA diagram",
        "category": "Transitrix",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "transitrixStudio.previewActivities",
        "title": "Transitrix: Preview activity network diagram",
        "category": "Transitrix",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "transitrixStudio.previewBlocks",
        "title": "Transitrix: Preview nested block diagram",
        "category": "Transitrix",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "transitrixStudio.saveBlocksAsSvg",
        "title": "Transitrix: Save block diagram as SVG",
        "category": "Transitrix",
        "icon": "$(save)"
      },
      {
        "command": "transitrixStudio.saveGoalsAsSvg",
        "title": "Transitrix: Save goal tree as SVG",
        "category": "Transitrix",
        "icon": "$(save)"
      },
      {
        "command": "transitrixStudio.saveFGCAAsSvg",
        "title": "Transitrix: Save FGCA diagram as SVG",
        "category": "Transitrix",
        "icon": "$(save)"
      },
      {
        "command": "transitrixStudio.saveFGAAsSvg",
        "title": "Transitrix: Save FGA diagram as SVG",
        "category": "Transitrix",
        "icon": "$(save)"
      },
      {
        "command": "transitrixStudio.saveActivitiesAsSvg",
        "title": "Transitrix: Save activity network as SVG",
        "category": "Transitrix",
        "icon": "$(save)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /\\.(cervin|bpmn)\\.yaml$/",
          "command": "cervin.openPreview",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.goals\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewGoals",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.fgca\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewFGCA",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.fga\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewFGA",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.activities\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewActivities",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.blocks\\.transitrix\\.txt$/",
          "command": "transitrixStudio.previewBlocks",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.blocks\\.transitrix\\.txt$/",
          "command": "transitrixStudio.saveBlocksAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == blocksPreview",
          "command": "transitrixStudio.saveBlocksAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.goals\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveGoalsAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == goalsPreview",
          "command": "transitrixStudio.saveGoalsAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.fgca\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveFGCAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == fgcaPreview",
          "command": "transitrixStudio.saveFGCAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.fga\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveFGAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == fgaPreview",
          "command": "transitrixStudio.saveFGAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.activities\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveActivitiesAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == activitiesPreview",
          "command": "transitrixStudio.saveActivitiesAsSvg",
          "group": "navigation@-9"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "cd .. && npm run extension:prep"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bpmn-moddle": "^10.0.0",
    "elkjs": "^0.9.3",
    "js-yaml": "^4.1.0",
    "xmlbuilder2": "^3.1.1"
  }
}
