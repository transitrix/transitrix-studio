        "category": "Transitrix"
      },
      {
        "command": "transitrixStudio.copyBlocksAsPng",
        "title": "Transitrix: Copy block diagram as PNG",
        "category": "Transitrix"
      },
      {
        "command": "transitrixStudio.saveGoalsAsPng",
