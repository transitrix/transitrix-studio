      },
      {
        "command": "transitrixStudio.openCurvatureSettings",
        "title": "Transitrix: Open diagram edge-curvature settings",
        "category": "Transitrix",
        "icon": "$(settings-gear)"
      },
      {
        "command": "transitrixStudio.openScopeSettings",
        "title": "Transitrix: Open diagram scope (level/root) settings",
        "category": "Transitrix",
        "icon": "$(filter)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /\\.(cervin|bpmn)\\.yaml$/",
          "command": "cervin.openPreview",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.goals\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewGoals",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.fgca\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewFGCA",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.fga\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewFGA",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.activities\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewActivities",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.blocks\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewBlocks",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.blocks\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveBlocksAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == blocksPreview",
          "command": "transitrixStudio.saveBlocksAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.goals\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveGoalsAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == goalsPreview",
          "command": "transitrixStudio.saveGoalsAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.fgca\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveFGCAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == fgcaPreview",
          "command": "transitrixStudio.saveFGCAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.fga\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveFGAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == fgaPreview",
          "command": "transitrixStudio.saveFGAAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.activities\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveActivitiesAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == activitiesPreview",
          "command": "transitrixStudio.saveActivitiesAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.products\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewProducts",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.applications\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewApplications",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.process-map\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewProcessMap",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.scenarios\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewScenarios",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.capability-map\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewCapabilityMap",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.process-blueprint\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewProcessBlueprint",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.process-blueprint\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveProcessBlueprintAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == processBlueprintPreview",
          "command": "transitrixStudio.saveProcessBlueprintAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.activity-card\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewActivityCard",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.activity-card\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveActivityCardAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == activityCardPreview",
          "command": "transitrixStudio.saveActivityCardAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "resourceFilename =~ /\\.issues\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.previewIssues",
          "group": "navigation@-10"
        },
        {
          "when": "resourceFilename =~ /\\.issues\\.transitrix\\.yaml$/",
          "command": "transitrixStudio.saveIssuesAsSvg",
          "group": "navigation@-9"
        },
        {
          "when": "activeWebviewPanelId == issuesPreview",
          "command": "transitrixStudio.saveIssuesAsSvg",
          "group": "navigation@-9"
        }
      ]
    }
  },
