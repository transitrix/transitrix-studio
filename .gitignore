node_modules/

# Archive trees — never commit. Canonical `.archive/` and legacy `0. archive/`
# (leading space) are both ignored at ANY depth.
**/.archive/
**/0. archive/

dist/
# Compiled output must never land beside the TypeScript sources. The diagrams
# package builds to dist/ (above); these patterns are a backstop so a stray
# bare `tsc` / `npx tsc <file>.ts` run can't litter the pure-TS src tree with
# emitted .js/.d.ts and have it show up as untracked churn.
packages/diagrams/src/**/*.js
packages/diagrams/src/**/*.js.map
packages/diagrams/src/**/*.d.ts
packages/diagrams/src/**/*.d.ts.map
extension/out/
extension/compiler/
# Slim @transitrix/cli package - dist/ + schemas/ are regenerated by
# scripts/build-cli-package.mjs (workspace prepack). Source committed under
# packages/cli/ is the package metadata (package.json, README.md, LICENSE);
# the build output is not.
packages/cli/schemas/
# The entire media/ tree is build output: build-webview.mjs wipes and
# regenerates it on every extension:prep (bundled viewer.js + the vendored
# bpmn-js / diagram-js CSS and font assets copied from node_modules). It was
# previously tracked, which caused a perpetual CRLF "modified" churn on
# Windows checkouts. Treated like out/ and compiler/ — regenerated, not
# committed (vscode:prepublish and the F5 task both run extension:prep).
extension/media/
extension/schemas/
extension/backends/
# The extension sub-package's lockfile is not authoritative — the build
# pipeline at the root (extension:prep) installs runtime deps into a clean
# temp tree and copies them in. A committed lockfile here drifts from the
# real surface and pollutes the VSIX. Keep `npm install` in extension/ from
# regenerating one.
extension/package-lock.json
# Packaged .vsix artifacts land in output/ (see package-extension). Ignore the
# contents but keep the directory itself so `vsce package --out ../output/`
# works on a fresh clone.
output/*
!output/.gitkeep
*.vsix
# Python bytecode
__pycache__/
*.pyc
*.pyo

# macOS / Windows filesystem noise
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
__MACOSX/
.Spotlight-V100
.Trashes
.fseventsd
Thumbs.db
ehthumbs.db
Desktop.ini
*.log

# Agent-context files (internal only — never publish)
STRATEGIC_BRIEF.md
**/STRATEGIC_BRIEF.md
CLAUDE.md
**/CLAUDE.md
*ai-agent-rules*.md
**/*ai-agent-rules*.md

# Maintainer-local roadmap (internal planning, not part of the published surface)
roadmap.md

# Claude Code worktrees and per-agent state
# (commands/*.md skill definitions are tracked — see exceptions below)
.claude/**
**/.claude/**
!.claude/commands/
!.claude/commands/*.md

# Internal / scratch files (not for public repo)
stakeholders.md
test-comprehensive.mjs
test-extreme.mjs
test-params.mjs
test-parse.mjs
quick-build-extension.sh
quick-start-util.sh

# Per-user display preferences (lane toggles, decoration preferences).
# The folder is tracked via .gitkeep; its contents stay local only.
.transitrix/display-preferences/*
!.transitrix/display-preferences/.gitkeep

# Local environment / secrets
.env
.env.*
!.env.example
.env.local
.env.*.local
*.pem
*.key

# Local agent-runner launchers (internal � never publish)
run-*-agent.ps1
**/run-*-agent.ps1
