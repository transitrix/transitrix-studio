{
  "name": "transitrix-studio",
  "version": "3.0.8",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "VS Code extension and CLI for editing and previewing Transitrix diagrams (BPMN, Goals, DGCA, …).",
  "license": "MIT",
  "homepage": "https://github.com/transitrix/transitrix-studio#readme",
  "bugs": {
    "url": "https://github.com/transitrix/transitrix-studio/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/transitrix/transitrix-studio.git"
  },
  "keywords": [
    "bpmn",
    "transitrix",
    "diagrams",
    "enterprise-architecture"
  ],
  "type": "module",
  "transitrix": {
    "methodologyVersion": "0.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "compile": "npm run build:diagrams && tsc --noEmit",
    "compile:extension": "tsc -p extension/tsconfig.json --noEmit",
    "build": "npm run build:diagrams && tsc -p tsconfig.build.json",
    "build:diagrams": "npm --workspace packages/diagrams run build",
    "build:webview": "node scripts/build-webview.mjs",
    "build:webview-bundle": "node scripts/build-webview-bundle.mjs",
    "extension:bundle": "node scripts/build-extension-bundle.mjs",
    "extension:prep": "npm run build:webview && npm run build:plantuml-assets && npm run build:diagrams && node scripts/build-compiler-bundle.mjs && npm run extension:bundle",
    "pretest": "npm run build",
    "test": "npm run test:core && npm run test:diagrams",
    "test:core": "vitest run",
    "test:diagrams": "npm --workspace packages/diagrams test",
    "test:watch": "vitest",
    "metrics:baseline": "npm run build && node scripts/measure-baseline.mjs",
    "transitrix": "tsx src/cli.ts",
    "ui:dev": "vite dev --config ui/vite.config.ts",
    "ui:build": "vite build --config ui/vite.config.ts",
    "ui:preview": "npm run build && npm run ui:build && vite preview --config ui/vite.config.ts",
    "bump-extension-version": "node scripts/bump-extension-version.mjs",
    "verify-extension-packaging": "node scripts/verify-extension-packaging.mjs",
    "check:no-cervin-yaml": "node scripts/check-no-cervin-yaml.mjs",
    "package-extension": "node scripts/package-extension.mjs",
    "build:cli-package": "node scripts/build-cli-package.mjs",
    "sync-examples": "node scripts/sync-examples-from-methodology.mjs",
    "build:plantuml-assets": "node scripts/build-plantuml-assets.mjs"
  },
  "bin": {
    "transitrix": "./dist/cli.js"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "elkjs": "^0.9.3",
    "js-yaml": "^4.1.0",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@plantuml/core": "^1.2026.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "bpmn-js": "^18.3.2",
    "bpmn-moddle": "^10.0.0",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.6",
    "vitest": "^3.2.1"
  }
}
