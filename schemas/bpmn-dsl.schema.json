{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://transitrix.com/schema/bpmn-dsl-v1.json",
  "title": "Transitrix BPMN YAML DSL (BPMN process)",
  "type": "object",
  "additionalProperties": false,
  "required": ["process"],
  "properties": {
    "notation": {
      "type": "string",
      "const": "bpmn",
      "description": "Canonical notation header per notations/CONTRACT.md. Required by the methodology; optional in this schema for backward compatibility with files predating the canonical header."
    },
    "spec_version": {
      "type": "string",
      "description": "Notation spec version this document conforms to. Reserved per CONTRACT.md; accepted but not enforced."
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "pools", "flows"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "pools": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "$ref": "#/definitions/pool" }
        },
        "flows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/flow" }
        },
        "associations": {
          "type": "array",
          "items": { "$ref": "#/definitions/association" }
        }
      }
    }
  },
  "definitions": {
    "pool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "lanes"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/lane" }
        }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "elements"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/element" }
        },
        "performed_by_role": {
          "type": "string",
          "description": "Canonical ROLE-… element ID for the actor responsible for this lane."
        },
        "supported_by_application": {
          "type": "string",
          "description": "Canonical APPLICATION-… element ID for the default supporting system in this lane."
        }
      }
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "startEvent",
            "endEvent",
            "task",
            "userTask",
            "serviceTask",
            "exclusiveGateway",
            "parallelGateway",
            "inclusiveGateway",
            "intermediateMessageEvent",
            "intermediateTimerEvent",
            "dataObject"
          ]
        },
        "name": { "type": "string" },
        "supported_by_application": {
          "type": "string",
          "description": "Canonical APPLICATION-… element ID for the supporting system for this specific element (overrides lane default)."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "startEvent",
                  "endEvent",
                  "intermediateMessageEvent",
                  "intermediateTimerEvent",
                  "dataObject"
                ]
              }
            }
          },
          "then": { "properties": { "name": {} } },
          "else": {
            "required": ["name"],
            "properties": { "name": { "type": "string", "minLength": 1 } }
          }
        }
      ]
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "from": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "to": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "condition": { "type": "string", "minLength": 1 },
        "default": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "association": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "from": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "to": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        }
      }
    }
  }
}
